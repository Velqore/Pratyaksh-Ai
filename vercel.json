{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --no-frozen-lockfile --config.confirmModulesPurge=false",
  "buildCommand": "pnpm --filter @workspace/api-server build && pnpm --filter @workspace/pratyaksh build",
  "outputDirectory": "artifacts/pratyaksh/dist/public",
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "artifacts/api-server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api", "destination": "/api/index.mjs" },
    { "source": "/api/(.*)", "destination": "/api/index.mjs" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production",
    "DATABASE_URL": "postgresql://postgres:password@helium/heliumdb?sslmode=disable",
    "SMTP_HOST": "smtp.gmail.com",
    "SMTP_PORT": "587",
    "SMTP_SECURE": "false",
    "SMTP_USER": "pratyaksh.ai.app@gmail.com",
    "SMTP_PASS": "essc ruia qkqz orvh",
    "SMTP_FROM": "pratyaksh.ai.app@gmail.com",
    "SMTP_FROM_NAME": "Pratyaksh Forensic AI"
  }
}
